# ── Web Push (browsers / PWA) ──
# Generate with: npm run keys:vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@sierro.app

# Put the SAME public key into the frontend build env:
#   VITE_VAPID_PUBLIC_KEY=<VAPID_PUBLIC_KEY>

# ── FCM (Android native) ──
# Path to a Firebase service-account JSON (applicationDefault credential)
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# ── APNs (iOS native) ──
APNS_KEY_PATH=./AuthKey_XXXX.p8
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.sierro.energyapp
APNS_PRODUCTION=false

# ── Server ──
PORT=8787
STORE_FILE=./tokens.json
# Shared secret the device backend must send as X-Internal-Key to POST /notify
INTERNAL_KEY=
