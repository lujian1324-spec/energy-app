# ── Web Push (browsers / PWA) ──
# Generate with: npm run keys:vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@sierro.app

# Put the SAME public key into the frontend build env:
#   VITE_VAPID_PUBLIC_KEY=<VAPID_PUBLIC_KEY>

# ── FCM (Android native) ──
# Path to a Firebase service-account JSON (applicationDefault credential)
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# ── APNs (iOS native) ──
APNS_KEY_PATH=./AuthKey_XXXX.p8
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.sierro.energyapp
APNS_PRODUCTION=false

# ── Server ──
PORT=8787
STORE_FILE=./tokens.json
# Shared secret the device backend must send as X-Internal-Key to POST /notify
INTERNAL_KEY=

# ── Poller (closed-app delivery) ──
# The in-process poller logs into the official IoT Open API with each user's
# uploaded refresh token, reads their device state, and pushes outage/low-battery/
# solar alerts. Only runs when POLLER_ENABLED=true.
POLLER_ENABLED=false
API_BASE=https://solar.siseli.com/apis
IOT_APP_ID=rYGQpmYU5k
IOT_APP_SECRET=GhJXQYEHphHlyiqYnBGE
POLL_INTERVAL_MS=60000
RENOTIFY_THROTTLE_MS=1800000
# AES-256-GCM key for encrypting stored refresh tokens at rest. REQUIRED in prod.
# Generate: openssl rand -hex 32
TOKEN_ENC_KEY=
