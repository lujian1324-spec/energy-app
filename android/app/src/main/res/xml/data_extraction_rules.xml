<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ 备份/迁移规则：禁止云备份与设备迁移导出应用数据。
  App 在本地存有认证 token（IOT-Token / refresh token），不应被 adb backup 或
  设备迁移导出。cloud-backup 与 device-transfer 均排除全部数据。
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
